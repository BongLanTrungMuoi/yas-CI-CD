pipeline {
    agent any

    environment {
        DOCKER_HUB_USER = 'melyen'
        DOCKER_CRED_ID  = 'dockerhub-token'
    }

    stages {
        stage('1. Identify Changes') {
            steps {
                script {
                    // Lấy Short Commit ID làm Tag cho Image
                    env.GIT_TAG = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
                    
                    // Xác định các thư mục ở root có thay đổi code
                    def changedFiles = ""
                    try {
                        changedFiles = sh(script: "git diff --name-only HEAD~1 HEAD | cut -d/ -f1 | sort -u", returnStdout: true).trim()
                    } catch (Exception e) {
                        echo "Warning: Could not get git diff (possibly first build). Checking all directories."
                        changedFiles = sh(script: "ls -d */ | cut -f1 -d'/'", returnStdout: true).trim()
                    }
                    
                    // Danh sách các service hợp lệ trong dự án yas của bạn
                    def validServices = ['cart', 'customer', 'inventory', 'product', 'order', 'identity', 'search', 'media', 'payment', 'location', 'backoffice', 'storefront']
                    
                    def targetServices = changedFiles.split('\n').findAll { validServices.contains(it) }
                    
                    env.SERVICES_TO_BUILD = targetServices.join(',')
                    echo "Target services identified: ${env.SERVICES_TO_BUILD}"
                }
            }
        }

        stage('2. Build & Push Services') {
            when {
                expression { env.SERVICES_TO_BUILD != "" }
            }
            steps {
                script {
                    def serviceList = env.SERVICES_TO_BUILD.split(',')
                    
                    for (serviceName in serviceList) {
                        stage("Service: ${serviceName}") {
                            echo "--- Starting Build for Service: ${serviceName} ---"
                            
                            // A. Build JAR dùng Docker Maven (Sử dụng JDK 25 để khớp với code)
                            // Lưu ý: Volume /var/lib/jenkins/.m2 giúp cache lại thư viện để build nhanh hơn
                            sh """
                                docker run --rm \
                                -v /var/lib/jenkins/.m2:/root/.m2 \
                                -v \$(pwd):/app \
                                -w /app \
                                maven:3.9-eclipse-temurin-25-alpine \
                                mvn clean package -pl ${serviceName} -am -DskipTests
                            """

                            // B. Build & Push Docker Image lên Docker Hub
                            dir("${serviceName}") {
                                def fullImageName = "${DOCKER_HUB_USER}/yas-${serviceName}:${env.GIT_TAG}"
                                
                                withCredentials([usernamePassword(credentialsId: "${DOCKER_CRED_ID}", passwordVariable: 'PASS', usernameVariable: 'USER')]) {
                                    echo "🔨 Building Docker Image: ${fullImageName}"
                                    sh "docker build -t ${fullImageName} ."
                                    
                                    echo "🚀 Pushing Image to Docker Hub..."
                                    sh "echo \$PASS | docker login -u \$USER --password-stdin"
                                    sh "docker push ${fullImageName}"
                                    sh "docker logout"
                                }
                            }
                            echo "--- Finished ${serviceName} ---"
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            // Cập nhật trạng thái CI lên GitHub Checks
            publishChecks name: 'Jenkins CI',
                title: 'CI Status',
                summary: "Built Services: ${env.SERVICES_TO_BUILD ?: 'None'}. Tag: ${env.GIT_TAG}",
                conclusion: "${currentBuild.result ?: 'SUCCESS'}"
        }
        cleanup {
            // Dọn dẹp các workspace tạm nếu cần
            cleanWs()
        }
    }
}