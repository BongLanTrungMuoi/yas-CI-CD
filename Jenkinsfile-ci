pipeline {
    agent any

    environment {
        DOCKER_HUB_USER = 'melyen'
        DOCKER_CRED_ID  = 'dockerhub-token'
        
        VALID_SERVICES = 'cart,customer,inventory,product,order,identity,search,media,payment,location,backoffice-bff,backoffice-ui,storefront-bff,storefront-ui'
    }

    stages {
        stage('1. Identify Changes') {
            steps {
                script {
                    // 1. Lấy Short Commit ID làm Tag duy nhất cho Image
                    env.GIT_TAG = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
                    
                    // 2. Xác định các service thay đổi code (so sánh giữa các lần push)
                    def changedFiles = ""
                    try {
                        // Sử dụng BEFORE_REVISION và AFTER_REVISION của Jenkins để bắt mọi commit trong lần push
                        changedFiles = sh(script: "git diff --name-only ${env.BEFORE_REVISION} ${env.AFTER_REVISION} | cut -d/ -f1 | sort -u", returnStdout: true).trim()
                    } catch (e) {
                        // Nếu là build đầu tiên hoặc lỗi, so sánh với commit trước đó
                        echo "Warning: Fallback to HEAD~1 diff."
                        changedFiles = sh(script: "git diff --name-only HEAD~1 HEAD | cut -d/ -f1 | sort -u", returnStdout: true).trim()
                    }
                    
                    def validList = env.VALID_SERVICES.split(',')
                    def targetServices = changedFiles.split('\n').findAll { validList.contains(it) }
                    
                    if (targetServices.isEmpty()) {
                        currentBuild.result = 'SUCCESS'
                        error("Không có service nào thay đổi code. Kết thúc pipeline.")
                    }

                    env.SERVICES_TO_BUILD = targetServices.join(',')
                    echo "🚀 Các service sẽ được build: ${env.SERVICES_TO_BUILD}"
                    echo "🏷️ Image Tag (Commit ID): ${env.GIT_TAG}"
                }
            }
        }

        stage('2. Maven Build (JAR)') {
            steps {
                script {
                    def serviceList = env.SERVICES_TO_BUILD.split(',')
                    // Gom tất cả service vào 1 lệnh build để Maven tối ưu hóa dependency
                    def mavenProjectList = serviceList.collect { "-pl ${it}" }.join(' ')
                    
                    echo "🛠️ Đang build JAR cho các module: ${mavenProjectList}"
                    
                    sh """
                        docker run --rm \
                        -v /var/lib/jenkins/.m2:/root/.m2 \
                        -v \$(pwd):/app \
                        -w /app \
                        maven:3.9-eclipse-temurin-25-alpine \
                        mvn clean package ${mavenProjectList} -am -DskipTests
                    """
                }
            }
        }

        stage('3. Docker Build & Push') {
            steps {
                script {
                    def serviceList = env.SERVICES_TO_BUILD.split(',')
                    
                    // Sử dụng Docker Pipeline Plugin để quản lý Login/Logout tự động
                    docker.withRegistry('https://index.docker.io/v1/', "${DOCKER_CRED_ID}") {
                        for (svc in serviceList) {
                            dir("${svc}") {
                                def imageName = "${DOCKER_HUB_USER}/yas-${svc}:${env.GIT_TAG}"
                                
                                echo "🔨 Building Image: ${imageName}"
                                def customImage = docker.build(imageName)
                                
                                echo "🚀 Pushing Image: ${imageName}"
                                customImage.push()
                                
                                // Nếu là branch main, đẩy thêm tag 'latest'
                                if (env.BRANCH_NAME == 'main') {
                                    echo "🏷️ Gán thêm tag latest cho ${svc}"
                                    customImage.push('latest')
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    post {
        success {
            script {
                echo "✅ CI hoàn tất thành công!"
                echo "Thông tin cho Job CD: Tag cần sử dụng là: ${env.GIT_TAG}"
            }
        }
        failure {
            echo "❌ CI thất bại. Kiểm tra lại log build phía trên."
        }
        always {
            // Dọn dẹp Workspace sau khi chạy xong
            cleanWs()
        }
    }
}