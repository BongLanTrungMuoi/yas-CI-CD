pipeline {
    agent any

    environment {
        DOCKER_HUB_USER = 'melyen'
        DOCKER_CRED_ID  = 'dockerhub-token'
        
        // CẬP NHẬT: Đảm bảo tên ở đây khớp 100% với tên THƯ MỤC trên Git
        VALID_SERVICES = 'cart,customer,inventory,product,order,identity,search,media,payment,location,backoffice-bff,backoffice-ui,storefront-bff,storefront-ui,tax,webhook,sampledata,recommendation,delivery'
    }

    stages {
        stage('1. Initialize & Identify') {
            steps {
                script {
                    env.GIT_TAG = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
                    echo "🚀 Starting build for Commit: ${env.GIT_TAG}"
                    
                    def changedFiles = ""
                    if (env.BEFORE_REVISION && env.AFTER_REVISION && env.BEFORE_REVISION != "null") {
                        changedFiles = sh(script: "git diff --name-only ${env.BEFORE_REVISION} ${env.AFTER_REVISION} | cut -d/ -f1 | sort -u", returnStdout: true).trim()
                    } else {
                        try {
                            changedFiles = sh(script: "git diff --name-only HEAD~1 HEAD | cut -d/ -f1 | sort -u", returnStdout: true).trim()
                        } catch (e) {
                            changedFiles = sh(script: "ls -d */ | cut -f1 -d'/'", returnStdout: true).trim()
                        }
                    }
                    
                    def mavenServices = ['cart', 'customer', 'inventory', 'product', 'order', 'media', 'payment', 'location', 'backoffice-bff', 'storefront-bff', 'search', 'tax', 'webhook', 'sampledata', 'recommendation', 'delivery', 'common-library']
                    def nodeServices = ['backoffice', 'storefront']
                    
                    def targetServices = changedFiles.split('\n').findAll { (mavenServices + nodeServices).contains(it) }
                    
                    if (targetServices.isEmpty()) {
                        env.SERVICES_TO_BUILD = ""
                        echo "⏩ No valid services changed."
                    } else {
                        env.SERVICES_TO_BUILD = targetServices.join(',')
                        echo "🎯 Target services identified: ${env.SERVICES_TO_BUILD}"
                    }
                    
                    env.MAVEN_LIST = mavenServices.join(',')
                    env.NODE_LIST = nodeServices.join(',')
                }
            }
        }

        stage('2. Maven Build (JAR)') {
            when { expression { env.SERVICES_TO_BUILD != "" } }
            steps {
                script {
                    def serviceList = env.SERVICES_TO_BUILD.split(',')
                    // Sử dụng dấu ":" là chuẩn nhất cho Maven Artifact ID
                    def mavenProjectList = serviceList.collect { ":${it}" }.join(',')
                    
                    echo "🛠️ Building JARs for: ${mavenProjectList}"
                    
                    sh """
                        docker run --rm \
                        -v /var/lib/jenkins/.m2:/root/.m2 \
                        -v \$(pwd):/app \
                        -w /app \
                        maven:3.9-eclipse-temurin-21-alpine \
                        /bin/sh -c "ls -la && mvn clean package -pl ${mavenProjectList} -am -DskipTests"
                    """
                }
            }
            steps {
                script {
                    def serviceList = env.SERVICES_TO_BUILD.split(',')
                    docker.withRegistry('https://index.docker.io/v1/', "${DOCKER_CRED_ID}") {
                        for (serviceName in serviceList) {
                            dir("${serviceName}") {
                                def fullImageName = "${DOCKER_HUB_USER}/yas-${serviceName}:${env.GIT_TAG}"
                                echo "🔨 Building Docker Image: ${fullImageName}"
                                def customImage = docker.build(fullImageName)
                                customImage.push()
                                
                                if (env.BRANCH_NAME == 'main') {
                                    customImage.push('latest')
                                }

                                dir(name) {
                                    def fullImageName = "${env.DOCKER_HUB_USER}/yas-${name}:${env.GIT_TAG}"
                                    
                                    withCredentials([usernamePassword(credentialsId: env.DOCKER_CRED_ID, passwordVariable: 'PASS', usernameVariable: 'USER')]) {
                                        echo "🔨 Building Docker Image: ${fullImageName}"
                                        sh "docker build -t ${fullImageName} ."
                                        
                                        echo "🚀 Pushing Image: ${fullImageName}"
                                        sh "echo \$PASS | docker login -u \$USER --password-stdin"
                                        sh "docker push ${fullImageName}"
                                        
                                        if (env.TAG_NAME) {
                                            sh "docker tag ${fullImageName} ${env.DOCKER_HUB_USER}/yas-${name}:${env.TAG_NAME}"
                                            sh "docker push ${env.DOCKER_HUB_USER}/yas-${name}:${env.TAG_NAME}"
                                        }
                                        
                                        if (env.BRANCH_NAME == 'main') {
                                            sh "docker tag ${fullImageName} ${env.DOCKER_HUB_USER}/yas-${name}:latest"
                                            sh "docker push ${env.DOCKER_HUB_USER}/yas-${name}:latest"
                                        }
                                        sh "docker logout"
                                    }
                                }
                                echo "✅ Finished ${name}"
                            }
                        }
                    }
                    
                    parallel builds
                }
            }
        }

        stage('3. Trigger ArgoCD') {
            when {
                expression { env.SERVICES_TO_BUILD != "" }
            }
            steps {
                script {
                    // Nếu có tag (v1.2.3) thì deploy staging, ngược lại deploy dev
                    def targetEnv = (env.TAG_NAME && env.TAG_NAME.startsWith('v')) ? 'staging' : 'dev'
                    def targetTag = env.TAG_NAME ?: ''
                    def branch = env.BRANCH_NAME ?: 'main'
                    
                    echo "🚀 Triggering ArgoCD Sync Job [Env: ${targetEnv.toUpperCase()}, Tag: ${targetTag}, Branch: ${branch}]"
                    
                    build job: 'yas-argocd', 
                        parameters: [
                            string(name: 'TARGET_ENV', value: targetEnv),
                            string(name: 'TARGET_TAG', value: targetTag),
                            string(name: 'common_branch', value: branch)
                        ],
                        wait: false
                }
            }
        }
    }

    post {
        always {
            // Chỉ chạy publishChecks nếu bạn đã sửa xong lỗi 403 GitHub App
            // publishChecks name: 'Jenkins CI', title: 'CI Status', conclusion: "${currentBuild.result}"
            cleanWs()
        }
    }
}