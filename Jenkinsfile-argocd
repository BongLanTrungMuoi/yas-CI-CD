pipeline {
    agent any

    options {
        // Tự quản lý checkout để sửa lỗi safe directory của Git
        skipDefaultCheckout()
        timeout(time: 1, unit: 'HOURS')
    }

    parameters {
        choice(name: 'TARGET_ENV', choices: ['dev', 'staging'], description: 'Environment to deploy to')
        string(name: 'TARGET_TAG', defaultValue: '', description: 'Specific tag to deploy (e.g., v1.2.3). Applies to ALL services.')
        // Tham số cho từng service — CI gửi commit SHA cho service có thay đổi
        // Mặc định là 'latest' cho các service không đổi
        string(name: 'backoffice_bff', defaultValue: 'latest', description: 'Image tag for backoffice-bff')
        string(name: 'backoffice_ui', defaultValue: 'latest', description: 'Image tag for backoffice-ui')
        string(name: 'storefront_bff', defaultValue: 'latest', description: 'Image tag for storefront-bff')
        string(name: 'storefront_ui', defaultValue: 'latest', description: 'Image tag for storefront-ui')
        string(name: 'cart', defaultValue: 'latest', description: 'Image tag for cart')
        string(name: 'customer', defaultValue: 'latest', description: 'Image tag for customer')
        string(name: 'delivery', defaultValue: 'latest', description: 'Image tag for delivery')
        string(name: 'inventory', defaultValue: 'latest', description: 'Image tag for inventory')
        string(name: 'location', defaultValue: 'latest', description: 'Image tag for location')
        string(name: 'media', defaultValue: 'latest', description: 'Image tag for media')
        string(name: 'order', defaultValue: 'latest', description: 'Image tag for order')
        string(name: 'payment', defaultValue: 'latest', description: 'Image tag for payment')
        string(name: 'product', defaultValue: 'latest', description: 'Image tag for product')
        string(name: 'promotion', defaultValue: 'latest', description: 'Image tag for promotion')
        string(name: 'rating', defaultValue: 'latest', description: 'Image tag for rating')
        string(name: 'search', defaultValue: 'latest', description: 'Image tag for search')
        string(name: 'tax', defaultValue: 'latest', description: 'Image tag for tax')
        string(name: 'recommendation', defaultValue: 'latest', description: 'Image tag for recommendation')
        string(name: 'webhook', defaultValue: 'latest', description: 'Image tag for webhook')
        string(name: 'sampledata', defaultValue: 'latest', description: 'Image tag for sampledata')
    }

    environment {
        GITOPS_REPO = 'https://github.com/BongLanTrungMuoi/yas-gitops.git'
        VALUES_FILE = "values-${params.TARGET_ENV}.yaml"
        ARGO_APP    = "yas-root-${params.TARGET_ENV}"
    }

    stages {
        stage('Initialize & Clone') {
            steps {
                script {
                    // Khắc phục lỗi bảo mật "dubious ownership" của Git trên Jenkins agent
                    sh "git config --global --add safe.directory '*'"
                    
                    // Dọn dẹp workspace (thay thế cho Wipe out repository & force clone)
                    deleteDir()
                    
                    // Checkout repo hiện tại để lấy các file cần thiết
                    checkout scm
                    
                    // Cô lập việc clone GitOps repo vào thư mục riêng
                    dir('yas-gitops') {
                        checkout scmGit(
                            branches: [[name: 'main']],
                            userRemoteConfigs: [[url: env.GITOPS_REPO]]
                        )
                    }
                }
            }
        }

        stage('Determine Tags & Update GitOps') {
            steps {
                script {
                    def services = [
                        "backoffice-bff", "backoffice-ui", "storefront-bff", "storefront-ui", 
                        "cart", "customer", "delivery", "inventory", "location", "media", "order", 
                        "payment", "product", "promotion", "rating", "search", "tax", 
                        "recommendation", "webhook", "sampledata"
                    ]
                    
                    def updatedServices = []
                    
                    for (svc in services) {
                        def paramName = svc.replace('-', '_')
                        // Nếu CI gửi image tag (commit SHA) thì dùng, nếu không thì mặc định 'latest'
                        def tag = (params."${paramName}" && params."${paramName}" != '') ? params."${paramName}" : 'latest'
                        
                        if (params.TARGET_TAG) {
                            tag = params.TARGET_TAG
                        }
                        
                        echo "Setting ${svc} to tag: ${tag}"
                        sh "yq -i '.services.\"${svc}\".tag = \"${tag}\"' yas-gitops/${env.VALUES_FILE}"
                        updatedServices << svc
                    }
                    
                    if (updatedServices.isEmpty()) {
                        echo "⚠️ No services were updated."
                    } else {
                        echo "✅ Updated services: ${updatedServices.join(', ')}"
                    }
                }
            }
        }

        stage('Git Commit and Push') {
            steps {
                script {
                    // Sử dụng ID GitHub App của bạn: 'jenkins-yas'
                    withCredentials([usernamePassword(credentialsId: 'jenkins-yas', 
                                    passwordVariable: 'GITHUB_APP_TOKEN', 
                                    usernameVariable: 'GITHUB_APP_USER')]) {
                        
                        dir('yas-gitops') {
                            sh "git config user.email jenkins-bot@yas.local"
                            sh "git config user.name 'Jenkins GitOps Bot'"
                            sh "git add ${env.VALUES_FILE}"
                            
                            // Tránh lỗi nếu không có thay đổi gì để commit
                            sh """
                                if git diff --cached --quiet; then
                                    echo "No changes to commit"
                                else
                                    git commit -m 'deploy: update ${params.TARGET_ENV} images (Build #${env.BUILD_NUMBER}) [skip ci]'
                                    # Đẩy code bằng token của GitHub App
                                    git push https://x-access-token:${GITHUB_APP_TOKEN}@github.com/BongLanTrungMuoi/yas-gitops.git HEAD:main
                                fi
                            """
                        }
                    }
                }
            }
        }

        stage('ArgoCD Sync & Info') {
            steps {
                script {
                    // ÉP Jenkins phải đọc file config chuẩn mà chúng ta vừa test thành công trên Terminal
                    withEnv(["KUBECONFIG=/var/jenkins_home/.kube/config"]) {
                        
                        echo "🔄 Đang kích hoạt Hard-Refresh cho ArgoCD Application..."
                        
                        // Chạy lệnh patch sử dụng file config xịn đã cấu hình
                        sh "kubectl patch application ${env.ARGO_APP} -n argocd --type merge -p '{\"metadata\":{\"annotations\":{\"argocd.argoproj.io/refresh\":\"hard\"}}}'"
                        
                        // Đọc thông tin Domain và EnvTag từ file YAML của GitOps
                        def domain = sh(script: "yq -r '.domain' yas-gitops/${env.VALUES_FILE}", returnStdout: true).trim()
                        def env_tag = sh(script: "yq -r '.envTag' yas-gitops/${env.VALUES_FILE}", returnStdout: true).trim()
                        
                        // Lấy IP động của máy Host (Chính là IP Gateway 172.17.0.1 đã tìm thấy)
                        def nodeIp = sh(script: "ip route | grep default | awk '{print \$3}'", returnStdout: true).trim()
                        
                        echo "=========================================================="
                        echo " 🎉 DEPLOYMENT TRIGGERED TO ${params.TARGET_ENV.toUpperCase()}"
                        echo "----------------------------------------------------------"
                        echo "Hãy copy đoạn dưới đây dán vào file /etc/hosts của bạn:"
                        echo "${nodeIp} identity-${env_tag}.${domain}"
                        echo "${nodeIp} backoffice-${env_tag}.${domain}"
                        echo "${nodeIp} storefront-${env_tag}.${domain}"
                        echo "${nodeIp} api-${env_tag}.${domain}"
                        echo "=========================================================="
                    }
                }
            }
        }
    }

    post {
        cleanup {
            cleanWs()
        }
    }
}